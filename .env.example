# ===========================================
# AI Job Agent - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your keys

# SerpAPI Key (get from https://serpapi.com)
SERPAPI_KEY=your_serpapi_key_here

# Google Gemini API Key (get from https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Personal Access Token (for repo operations if needed)
GITHUB_TOKEN=your_github_token_here

# LinkedIn Profile URL
LINKEDIN_URL=https://www.linkedin.com/in/your-profile

# Your personal info for auto-apply
APPLICANT_NAME=Your Full Name
APPLICANT_EMAIL=your.email@example.com
APPLICANT_PHONE=+91-XXXXXXXXXX

# Server settings
HOST=0.0.0.0
PORT=8000
